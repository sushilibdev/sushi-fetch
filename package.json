{
  "name": "sushi-fetch",
  "version": "1.0.0",
  "description": "🍣 A tiny but powerful data-fetching & caching library for modern JavaScript & TypeScript apps",
  "keywords": [
    "fetch",
    "http",
    "cache",
    "data-fetching",
    "typescript",
    "javascript",
    "api",
    "client",
    "request",
    "swr",
    "deduplication",
    "retry",
    "lightweight"
  ],
  "homepage": "https://github.com/sushilibdev/sushi-fetch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushilibdev/sushi-fetch.git"
  },
  "bugs": {
    "url": "https://github.com/sushilibdev/sushi-fetch/issues"
  },
  "author": {
    "name": "sushilibdev",
    "email": "sushilibdev@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean --define.process.env.NODE_ENV=\\\"production\\\" --no-splitting && npm run compress",
    "compress": "gzip -c dist/index.js > dist/index.js.gz",
    "watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "eslint": "^10.0.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
